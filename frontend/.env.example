# OpsPilot AI — frontend configuration
# Copy to .env and fill in. Never commit the real .env.

# ── Supabase (auth + optional storage/Postgres) ──────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Server-side fallbacks (used by TanStack Start server functions during SSR):
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# Optional. Needed only for server-side admin operations that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=

# ── Google Gemini (server-side AI for Supabase extraction/correlation) ────────
GOOGLE_API_KEY=

# ── OpsPilot FastAPI backend ──────────────────────────────────────────────────
# VITE_ prefix: available in the browser (only for read/poll calls, no secrets).
VITE_OPSPILOT_API_URL=http://localhost:8000

# No VITE_ prefix: server-side only — used by submitToBackendPipeline() server
# function to authenticate write calls. NEVER put this in a VITE_ variable.
# Must match OPSPILOT_API_KEYS in the backend .env.
OPSPILOT_API_URL=http://localhost:8000
OPSPILOT_API_KEY=
